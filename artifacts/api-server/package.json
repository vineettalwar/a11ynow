{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && export LD_LIBRARY_PATH=$(ls -d /nix/store/*-mesa-libgbm-*/lib 2>/dev/null | sort -V | tail -1):$(ls -d /nix/store/*-systemd-*/lib 2>/dev/null | sort -V | tail -1):$LD_LIBRARY_PATH && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@swc/helpers": "^0.5.21",
    "@types/pdfkit": "^0.17.6",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "axe-core": "^4.11.4",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "jsdom": "^29.1.1",
    "node-fetch": "^3.3.2",
    "pdfkit": "^0.18.0",
    "pino": "^9",
    "pino-http": "^10",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.1",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
