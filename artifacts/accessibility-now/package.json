{
  "name": "@workspace/accessibility-now",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "vite build --config vite.config.ts",
    "dev:next": "next dev --port 5181",
    "build:next": "next build --webpack",
    "build:opennext": "next build --webpack && node scripts/ensure-next-middleware-manifest.mjs && opennextjs-cloudflare build --skipNextBuild",
    "preview:cf": "pnpm run build:opennext && wrangler dev --config wrangler.jsonc",
    "deploy:cf:staging": "pnpm run build:opennext && opennextjs-cloudflare deploy --config wrangler.jsonc",
    "cf:typegen": "wrangler types --config wrangler.jsonc --env-interface CloudflareEnv cloudflare-env.d.ts",
    "sitemap": "tsx scripts/generate-sitemap.ts",
    "prebuild": "pnpm run sitemap",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/lib/**/*.test.ts"
  },
  "devDependencies": {
    "@hookform/resolvers": "^3.10.0",
