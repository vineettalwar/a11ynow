{
  "name": "@workspace/accessibility-now",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build --webpack",
    "start": "next start",
    "build:opennext": "next build --webpack && node scripts/write-next-middleware-manifest.mjs && opennextjs-cloudflare build --skipNextBuild",
    "preview": "pnpm run build:opennext && wrangler dev --config wrangler.jsonc",
    "preview:cf": "pnpm run build:opennext && wrangler dev --config wrangler.jsonc",
    "deploy": "pnpm run build:opennext && opennextjs-cloudflare deploy --config wrangler.jsonc",
    "deploy:cf:staging": "pnpm run build:opennext && opennextjs-cloudflare deploy --config wrangler.jsonc",
    "cf:typegen": "wrangler types --config wrangler.jsonc --env-interface CloudflareEnv cloudflare-env.d.ts",
    "d1:migrate:local": "wrangler d1 migrations apply accessibility-now-leads --local --config wrangler.jsonc",
    "d1:migrate:remote": "wrangler d1 migrations apply accessibility-now-leads --config wrangler.jsonc",
    "sitemap": "tsx scripts/generate-sitemap.ts",
    "prebuild": "pnpm run sitemap",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/lib/**/*.test.ts src/server/**/*.test.ts"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.3",
