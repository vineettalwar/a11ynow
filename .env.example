# ─────────────────────────────────────────────────────────────────────────────
# accessibility.now: environment variables
# Copy this file to .env and fill in the values before running locally.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (local Postgres, Docker, or your host)
DATABASE_URL=postgresql://user:password@localhost:5432/accessibility_now
#
# Local Docker dev DB (persistent volume; backup on `pnpm db:down`):
#   pnpm db:up
#   DATABASE_URL=postgresql://a11ynow:a11ynow_local_dev_only@127.0.0.1:5432/a11ynow
# Optional: copy docker/.env.example → docker/.env to change port/user/password/db name.

# ── Server port ───────────────────────────────────────────────────────────────
# Port the API server listens on (e.g. Replit). For `pnpm dev` / `pnpm dev:no-db`, a free
# port is chosen automatically and VITE_DEV_API_PROXY is set to match: you usually do not
# need PORT here. To pin the API port locally: A11YNOW_API_PORT=8080
PORT=8080

# Cloudflare Pages (frontend) — see docs/cloudflare-deployment.md
# API_ORIGIN=https://api.accessibility.now
# In production (NODE_ENV=production), localhost/private IPs are rejected unless set to 1.
# Set to 0 in staging if NODE_ENV is not production but you still want to block internal URLs.
# SCAN_ALLOW_PRIVATE_URLS=1
#
# Scan engine tuning (defaults shown; omit to use built-in values):
# SCAN_MAX_CONCURRENT=2          # Max simultaneous Playwright scans (hard cap 4)
# SCAN_TIMEOUT_MS=45000          # Base browser budget before profile/viewport extras
# SCAN_SCROLL_MAX_MS=12000       # Wall-clock cap for lazy-load scroll pass
# SHUTDOWN_DRAIN_MS=120000       # Max wait for in-flight scans on SIGTERM/SIGINT
#
# Cloudflare Browser Rendering worker (optional — see docs/cloudflare-deployment.md):
# SCAN_WORKER_URL=https://accessibility-now-scan.<subdomain>.workers.dev
# SCAN_WORKER_TOKEN=             # Bearer token; set matching secret on the worker

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# All five SMTP_* + FROM_EMAIL must be set for real email delivery.
# If any are absent the app runs in no-op mode: emails are logged but not sent.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@example.com

# ── GitHub backup (optional) ──────────────────────────────────────────────────
# Used by scripts/post-merge.sh to push the repo to a GitHub remote after each merge.
# Set GITHUB_REPO to the HTTPS URL (without embedded token).
GITHUB_TOKEN=ghp_yourPersonalAccessTokenHere
GITHUB_REPO=https://github.com/your-org/accessibility-now
